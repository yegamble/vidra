# .ralphrc - Ralph project configuration
# Generated by: ralph-setup
# Documentation: https://github.com/frankbria/ralph-claude-code

# Project identification
# NOTE: This is the MONOREPO ROOT and the Ralph ORCHESTRATOR launch point. Running
# `ralph` here advances BOTH projects (see .ralph/PROMPT.md); this file's settings
# (incl. CLAUDE_MODEL/CLAUDE_EFFORT below) apply to that orchestrator loop. Each loop
# the orchestrator also reads the target project's .ralph/ docs. The subdirectory
# .ralphrc files are used only by standalone per-subdir loops — do not run one of
# those while the root orchestrator is running (shared git history / main).
PROJECT_NAME="vidra-monorepo-root"
PROJECT_TYPE="generic"

# Claude Code CLI command
# If "claude" is not in your PATH, set to your installation:
#   "npx @anthropic-ai/claude-code"  (uses npx, no global install needed)
#   "/path/to/claude"                (custom path)
CLAUDE_CODE_CMD="claude"

# Model + reasoning effort applied to every Ralph invocation. ralph_loop.sh
# appends `--model "$CLAUDE_MODEL"` and `--effort "$CLAUDE_EFFORT"` (Issue #228).
#   CLAUDE_MODEL="opus"  -> the latest Opus (alias auto-tracks newest; pin to
#                           "claude-opus-4-8" for determinism).
#   CLAUDE_EFFORT="xhigh"-> highest reasoning effort Opus 4.8 supports; this is
#                           the headless equivalent of `/effort ultracode`
#                           (valid: low|medium|high|xhigh|max).
# Changing these requires restarting Ralph (config is read at launch).
CLAUDE_MODEL="opus"
CLAUDE_EFFORT="xhigh"

# Loop settings
MAX_CALLS_PER_HOUR=100
# Raised 15->25 (Ralph meta-repo fix 2026-07-01): opus+xhigh full vertical slices
# (migration + sqlc + service + handler + tests + `make ci` test-race + commit/push)
# routinely need >15m; loops were timing out mid-slice with work half-done.
CLAUDE_TIMEOUT_MINUTES=25
CLAUDE_OUTPUT_FORMAT="json"
# Token limit per hour (0 = disabled). One invocation can use 100k+ tokens.
# Recommended: 500000 for light use, 2000000 for heavy use.
# Set to a real ceiling: with opus+xhigh and MAX_CALLS_PER_HOUR effectively
# non-binding (loops take 6-15+ min), this is the only spend governor. (Ralph audit)
MAX_TOKENS_PER_HOUR=2000000

# Tool permissions
# Comma-separated list of allowed tools
# Safe git subcommands only - broad Bash(git *) allows destructive commands like git clean/git rm (Issue #149)
# Hardened (Ralph audit): dropped unused Bash(git merge *) (PROMPT uses pull --rebase,
# not merge); scoped Bash(curl *) to localhost only (its sole use is healthchecks —
# unrestricted curl is a network-egress/exfiltration vector for an unsupervised
# on-host agent). If a loop legitimately needs external HTTP, re-add Bash(curl *).
# Still broad and worth sandboxing (see SANDBOX_PROVIDER below): docker *, git push *.
ALLOWED_TOOLS="Write,Read,Edit,Bash(git add *),Bash(git commit *),Bash(git diff *),Bash(git log *),Bash(git status),Bash(git status *),Bash(git push *),Bash(git pull *),Bash(git fetch *),Bash(git checkout *),Bash(git branch *),Bash(git stash *),Bash(git tag *),Bash(go *),Bash(gofmt *),Bash(golangci-lint *),Bash(staticcheck *),Bash(sqlc *),Bash(migrate *),Bash(newman *),Bash(npm *),Bash(npx *),Bash(pnpm *),Bash(node *),Bash(playwright *),Bash(make *),Bash(docker *),Bash(docker-compose *),Bash(curl localhost:*),Bash(curl 127.0.0.1:*),Bash(curl http://localhost:*),Bash(curl http://127.0.0.1:*),Bash(cd *)"

# Sections in fix_plan.md whose unchecked items do NOT block Ralph exit.
OPTIONAL_SECTIONS="Optional / Deferred / Non-Blocking,Optional,Future,Future Enhancements,Nice to Have"

# Session management
SESSION_CONTINUITY=true
SESSION_EXPIRY_HOURS=24

# Task sources (for ralph enable --sync)
# Options: local, beads, github (comma-separated for multiple)
TASK_SOURCES="local"
GITHUB_TASK_LABEL="ralph-task"
BEADS_FILTER="status:open"

# Circuit breaker thresholds
# Raised 3->5 (Ralph meta-repo fix 2026-07-01): extra tolerance now that progress is
# measured across the child repos; guards against an occasional legit investigation loop.
CB_NO_PROGRESS_THRESHOLD=5
CB_SAME_ERROR_THRESHOLD=5
CB_OUTPUT_DECLINE_THRESHOLD=70

# Auto-update Claude CLI at startup
CLAUDE_AUTO_UPDATE=true

# Shell init file (optional)
# Source this file before running claude — useful when claude requires environment
# variables or PATH entries defined in a non-bash shell config (e.g. ~/.zshrc).
# Leave commented out unless needed.
#RALPH_SHELL_INIT_FILE="~/.zshrc"

# Docker sandbox execution (optional, Issue #74)
# Run Claude Code inside an isolated Docker container instead of on the host.
# Build the default image first: docker build -t ralph-sandbox ~/.ralph
# Uncomment to enable; CLI flags (--sandbox, --sandbox-image, ...) override these.
#SANDBOX_PROVIDER="docker"
#SANDBOX_DOCKER_IMAGE="ralph-sandbox:latest"
#SANDBOX_DOCKER_MEMORY="4g"
#SANDBOX_DOCKER_CPUS="2"
#SANDBOX_DOCKER_NETWORK="bridge"

# E2B cloud sandbox execution (optional, Issue #75)
# Run Claude Code inside an E2B cloud sandbox (e2b.dev) instead of on the host.
# Needs: pip install e2b, plus an API key via E2B_API_KEY or
# ~/.ralph/e2b_api_key (chmod 600) — never store the key in this file.
# Uncomment to enable; CLI flags (--sandbox e2b, --sandbox-template, ...) override these.
#SANDBOX_PROVIDER="e2b"
#SANDBOX_E2B_TEMPLATE="base"
#SANDBOX_E2B_TIMEOUT="3600"
#SANDBOX_E2B_KEEP_ALIVE="false"
#SANDBOX_E2B_MAX_COST=""
#SANDBOX_E2B_COST_ALERT=""
#SANDBOX_E2B_COST_PER_HOUR="0.10"
