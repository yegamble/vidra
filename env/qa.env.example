# Testing/QA (remote) — the environment the backed e2e suite models.
# These flags MUST stay in lock-step with vidra-user/.github/workflows/frontend-e2e-backed.yml
# (that workflow IS the QA contract). Canonical matrix: .ralph/specs/environments.md
VIDRA_ENV=test
HTTP_PORT=8080
FRONTEND_PORT=3000
PUBLIC_BASE_URL=https://qa-api.example.com
NEXT_PUBLIC_API_BASE_URL=https://qa-api.example.com
CORS_ALLOWED_ORIGINS=https://qa.example.com
RATE_LIMIT_ENABLED=false
DEV_MAIL_CAPTURE_ENABLED=true
HTTP_IMPORT_ALLOW_PRIVATE_URLS=true
MAIL_ENABLED=false
TRANSCODING_ENABLED=true
MALWARE_SCAN_ENABLED=false
STORAGE_BACKEND=local
FEDERATION_ENABLED=true
# FEDERATION_KEY_KEK=<base64 32 bytes — required when federation is on outside dev>
LIVE_INGEST_SECRET=e2e-ingest-secret
REGISTRATION_REQUIRE_APPROVAL=false
# vidra-search (internal autosuggest/search/recommendations service; core-only).
# NOT part of the frontend-e2e-backed.yml contract — that suite exercises the
# frontend against vidra-core only, so these meta-stack additions don't affect the
# lock-step note above. Concrete throwaway secret (flows to both core and search).
SEARCH_HTTP_PORT=8081
SEARCH_INTERNAL_SECRET=dev-insecure-internal-secret-change-me-0000
