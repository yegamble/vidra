# Local development (docker compose --env-file env/local.env ...)
# Copy to env/local.env and adjust. Canonical matrix: .ralph/specs/environments.md
VIDRA_ENV=development
HTTP_PORT=8080
FRONTEND_PORT=3000
PUBLIC_BASE_URL=http://localhost:8080
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Disabled for normal local iteration. Set true when manually exercising limits.
RATE_LIMIT_ENABLED=false
DEV_MAIL_CAPTURE_ENABLED=false
HTTP_IMPORT_ALLOW_PRIVATE_URLS=false
MAIL_ENABLED=false
TRANSCODING_ENABLED=true
MALWARE_SCAN_ENABLED=false
STORAGE_BACKEND=local
FEDERATION_ENABLED=false
REGISTRATION_REQUIRE_APPROVAL=false
# IPFS is opt-in. `make ipfs-live` overrides these for a real public provider plus
# the separate swarm.key'd private mirror. Leave public-network mode false during
# ordinary local development: publishing a CID is not reversible.
IPFS_ENABLED=false
IPFS_PUBLIC_NETWORK=false
IPFS_GATEWAY_URL=http://localhost:9090
IPFS_MIRROR_PRIVATE=false
# vidra-search (internal autosuggest/search/recommendations service; core-only,
# never browser-facing). SEARCH_HTTP_PORT is the host port for its :8080.
# SEARCH_INTERNAL_SECRET is the shared HMAC secret core and search authenticate
# with — it flows to BOTH api's SEARCH_INTERNAL_SECRET and search's INTERNAL_SECRET,
# so they always match. Dev default below; never use it in a shared deployment.
SEARCH_HTTP_PORT=8081
SEARCH_INTERNAL_SECRET=dev-insecure-internal-secret-change-me-0000
