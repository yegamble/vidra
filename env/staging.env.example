# Staging — production config with throwaway data. Same image tags as the prod
# candidate; separate secrets/domains. Canonical matrix: .ralph/specs/environments.md
VIDRA_ENV=production
HTTP_PORT=8080
FRONTEND_PORT=3000
PUBLIC_BASE_URL=https://stg-api.example.com
NEXT_PUBLIC_API_BASE_URL=https://stg-api.example.com
CORS_ALLOWED_ORIGINS=https://stg.example.com
RATE_LIMIT_ENABLED=true
DEV_MAIL_CAPTURE_ENABLED=false
HTTP_IMPORT_ALLOW_PRIVATE_URLS=false
MAIL_ENABLED=true
# SMTP_HOST= / SMTP_PORT= / SMTP_USERNAME= / SMTP_PASSWORD= / SMTP_FROM=  (secrets — set in the host secret store)
TRANSCODING_ENABLED=true
MALWARE_SCAN_ENABLED=true
# CLAMAV_ADDR=clamd:3310
STORAGE_BACKEND=s3
# STORAGE_S3_ENDPOINT= / STORAGE_S3_BUCKET= / STORAGE_S3_ACCESS_KEY= / STORAGE_S3_SECRET_KEY= (secrets)
FEDERATION_ENABLED=false
# FEDERATION_KEY_KEK=<base64 32 bytes — required in production when federation is on>
# JWT_SECRET=<strong secret — production refuses the dev default>
REGISTRATION_REQUIRE_APPROVAL=false
# vidra-search (internal autosuggest/search/recommendations service; core-only).
# SEARCH_INTERNAL_SECRET is the shared core↔search HMAC secret (>=32 bytes,
# required when the search integration is on) — set it from the host secret store,
# never commit a real value.
SEARCH_HTTP_PORT=8081
# SEARCH_INTERNAL_SECRET=<strong >=32-byte secret>
