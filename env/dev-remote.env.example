# Shared dev sandbox (remote). Canonical matrix: .ralph/specs/environments.md
VIDRA_ENV=development
HTTP_PORT=8080
FRONTEND_PORT=3000
PUBLIC_BASE_URL=https://dev-api.example.com
NEXT_PUBLIC_API_BASE_URL=https://dev-api.example.com
CORS_ALLOWED_ORIGINS=https://dev.example.com
RATE_LIMIT_ENABLED=true
DEV_MAIL_CAPTURE_ENABLED=false
HTTP_IMPORT_ALLOW_PRIVATE_URLS=false
MAIL_ENABLED=false
TRANSCODING_ENABLED=true
MALWARE_SCAN_ENABLED=false
STORAGE_BACKEND=local
FEDERATION_ENABLED=false
REGISTRATION_REQUIRE_APPROVAL=false
# vidra-search (internal autosuggest/search/recommendations service; core-only).
# SEARCH_INTERNAL_SECRET is the shared core↔search HMAC secret (flows to both the
# api and the search service). A shared remote sandbox sets a real value from the
# host env/secret store — never commit one.
SEARCH_HTTP_PORT=8081
# SEARCH_INTERNAL_SECRET=<strong >=32-byte secret — set from the host secret store>
