# Vidra core — example environment. Copy to .env and adjust for local dev.
# NEVER commit a real .env or any real secrets.

# Runtime environment: development | test | production
VIDRA_ENV=development

# Human-facing instance name (shown in NodeInfo / discovery).
INSTANCE_NAME=Vidra (dev)
# Whether public account signup is accepted (surfaced at GET /api/v1/instance).
REGISTRATION_ENABLED=true
# DEV-ONLY test seam. When true, account-security tokens (password reset, email
# verification) are held in memory and retrievable via GET /api/v1/dev/email-token
# instead of being mailed, so end-to-end tests can complete the token flows. The
# route exists only when this is on and the process warns loudly on boot.
# NEVER enable in production — it exposes single-use credentials.
DEV_MAIL_CAPTURE_ENABLED=false
# Optional instance about/legal metadata (surfaced at GET /api/v1/instance).
INSTANCE_DESCRIPTION=
INSTANCE_TERMS_URL=
INSTANCE_PRIVACY_URL=
INSTANCE_CONTACT_EMAIL=

# HTTP server
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
# Per-request context deadline (handlers/DB observe it; WriteTimeout is the hard cap).
HTTP_REQUEST_TIMEOUT=30s
# Max accepted request body size (Echo size string, e.g. 8M, 512K). Oversized -> 413.
HTTP_BODY_LIMIT=8M

# Rate limiting (Redis fixed-window, per client IP) on the /api surface.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW=1m
# Stricter per-IP budget (same window) for sensitive auth endpoints — login,
# register, and the password-reset / email-verify confirmations.
AUTH_RATE_LIMIT_REQUESTS=10

# Media storage. Backend is "local" for now (s3/ipfs land later); the local
# backend writes media under STORAGE_LOCAL_ROOT.
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=./data/media
# Max size of a single original-file upload (Echo size string). Overrides
# HTTP_BODY_LIMIT for the upload route only; oversized uploads get 413.
UPLOAD_MAX_SIZE=2G

# JWT access tokens (HS256). In production JWT_SECRET MUST be overridden with a
# strong value (>= 32 bytes); the dev default below is rejected when VIDRA_ENV=production.
JWT_SECRET=dev-insecure-jwt-secret-change-me-0000000000000000
JWT_ISSUER=vidra
JWT_AUDIENCE=vidra
JWT_ACCESS_TTL=15m
# Refresh-token (opaque, rotating) session lifetime.
JWT_REFRESH_TTL=720h

# PostgreSQL (matches docker-compose defaults)
POSTGRES_USER=vidra
POSTGRES_PASSWORD=vidra
POSTGRES_DB=vidra
POSTGRES_PORT=5432
DATABASE_URL=postgres://vidra:vidra@localhost:5432/vidra?sslmode=disable

# Redis (matches docker-compose defaults)
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# CORS: explicit, comma-separated allow-list. No wildcard in production.
CORS_ALLOWED_ORIGINS=http://localhost:3000
