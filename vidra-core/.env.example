# Vidra core — example environment. Copy to .env and adjust for local dev.
# NEVER commit a real .env or any real secrets.

# Runtime environment: development | test | production
VIDRA_ENV=development

# Human-facing instance name (shown in NodeInfo / discovery).
INSTANCE_NAME=Vidra (dev)

# HTTP server
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
# Per-request context deadline (handlers/DB observe it; WriteTimeout is the hard cap).
HTTP_REQUEST_TIMEOUT=30s
# Max accepted request body size (Echo size string, e.g. 8M, 512K). Oversized -> 413.
HTTP_BODY_LIMIT=8M

# PostgreSQL (matches docker-compose defaults)
POSTGRES_USER=vidra
POSTGRES_PASSWORD=vidra
POSTGRES_DB=vidra
POSTGRES_PORT=5432
DATABASE_URL=postgres://vidra:vidra@localhost:5432/vidra?sslmode=disable

# Redis (matches docker-compose defaults)
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# CORS: explicit, comma-separated allow-list. No wildcard in production.
CORS_ALLOWED_ORIGINS=http://localhost:3000
