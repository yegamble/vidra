#!/usr/bin/env bash
# Vidra monorepo STOP GUARD (mechanical enforcement)
#
# Rejects any commit that ADDS a new file at the repository root, except for an
# explicit allowlist of infrastructure files. All application code, tests, config,
# Docker, and docs must live inside vidra-core/ or vidra-user/.
#
# This backs up the instruction-level stop guard in .ralph/PROMPT.md so a root-run
# Ralph loop (or a human) physically cannot land code at the root.
#
# Enabled via:  git config core.hooksPath .githooks
# Bypass once (intentional):  git commit --no-verify

set -euo pipefail

# Root files/dirs that are allowed to be added at the repo root.
# Directories (vidra-core/, vidra-user/, .ralph/, .github/, .githooks/) are never
# flagged because their staged paths contain a "/".
allow_root() {
  case "$1" in
    README.md|LICENSE|.gitignore|.gitattributes|.ralphrc|.editorconfig|.DS_Store)
      return 0 ;;
    *) return 1 ;;
  esac
}

blocked=""
# --diff-filter=A: only newly ADDED files. Existing tracked root files are untouched.
while IFS= read -r f; do
  [ -z "$f" ] && continue
  # Only consider repo-root paths (no slash).
  case "$f" in
    */*) continue ;;
  esac
  allow_root "$f" && continue
  blocked="${blocked}  $f"$'\n'
done < <(git diff --cached --name-only --diff-filter=A)

if [ -n "$blocked" ]; then
  echo "⛔ STOP GUARD: refusing to add new file(s) at the monorepo root:" >&2
  printf '%s' "$blocked" >&2
  echo "" >&2
  echo "All application code/tests/config/docs belong in vidra-core/ or vidra-user/." >&2
  echo "Move the file into the correct project subdirectory and re-stage it." >&2
  echo "(Infra exceptions: README.md, LICENSE, .gitignore, .ralphrc. CI lives in .github/.)" >&2
  echo "Intentional override: git commit --no-verify" >&2
  exit 1
fi

# --- Documentation drift guard (vidra-core) ----------------------------------
# When a commit changes the backend HTTP surface (routes/handlers) or the
# database schema (migrations) but touches none of the docs that describe them,
# warn loudly. This is a non-blocking nudge: the authoritative enforcement is
# the TestOpenAPIContract drift test and the openapi.yml workflow, which fail CI
# if api/openapi.yaml is out of sync with the registered routes.
staged="$(git diff --cached --name-only --diff-filter=ACMR)"
touches() { printf '%s\n' "$staged" | grep -Eq "$1"; }

if touches '^vidra-core/internal/httpapi/.*\.go$' || touches '^vidra-core/migrations/'; then
  if ! touches '^vidra-core/api/openapi\.yaml$' \
    && ! touches '^vidra-core/README\.md$' \
    && ! touches '^vidra-core/\.ralph/specs/'; then
    echo "⚠️  DOC DRIFT: you changed vidra-core routes/handlers or migrations but" >&2
    echo "   did not touch api/openapi.yaml, README.md, or .ralph/specs/." >&2
    echo "   If the API contract or schema changed, update the docs in this commit." >&2
    echo "   (CI enforces route<->spec sync via TestOpenAPIContract / openapi.yml.)" >&2
    echo "" >&2
  fi
fi

exit 0
