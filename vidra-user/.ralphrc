# .ralphrc - Ralph configuration for vidra-user (Next.js / TypeScript frontend)
# Run Ralph from THIS directory:  cd vidra-user && ralph --live
# Documentation: https://github.com/frankbria/ralph-claude-code

# Project identification
PROJECT_NAME="vidra-user"
PROJECT_TYPE="node"

# Claude Code CLI command
CLAUDE_CODE_CMD="claude"

# Loop settings
MAX_CALLS_PER_HOUR=100
CLAUDE_TIMEOUT_MINUTES=15
CLAUDE_OUTPUT_FORMAT="json"
#MAX_TOKENS_PER_HOUR=0

# Tool permissions
# Safe git subcommands only + Node/Playwright/Docker tooling needed for frontend work.
ALLOWED_TOOLS="Write,Read,Edit,Bash(git add *),Bash(git commit *),Bash(git diff *),Bash(git log *),Bash(git status),Bash(git status *),Bash(git push *),Bash(git pull *),Bash(git fetch *),Bash(git checkout *),Bash(git branch *),Bash(git stash *),Bash(git merge *),Bash(git tag *),Bash(npm *),Bash(npx *),Bash(pnpm *),Bash(node *),Bash(playwright *),Bash(make *),Bash(docker *),Bash(docker-compose *),Bash(curl *)"

# Sections in fix_plan.md whose unchecked items do NOT block Ralph exit.
OPTIONAL_SECTIONS="Optional / Deferred / Non-Blocking,Optional,Future,Future Enhancements,Nice to Have"

# Session management
SESSION_CONTINUITY=true
SESSION_EXPIRY_HOURS=24

# Task sources
TASK_SOURCES="local"
GITHUB_TASK_LABEL="ralph-task"
BEADS_FILTER="status:open"

# Circuit breaker thresholds
CB_NO_PROGRESS_THRESHOLD=3
CB_SAME_ERROR_THRESHOLD=5
CB_OUTPUT_DECLINE_THRESHOLD=70

# Auto-update Claude CLI at startup
CLAUDE_AUTO_UPDATE=true
