# vidra-user — example environment. Copy to .env.local and adjust for local dev.
# Never commit a real .env or any secrets/tokens.

# Base URL of the vidra-core API the frontend calls. NEXT_PUBLIC_ is exposed to
# the browser, so this must be a non-secret URL only.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Logging level: debug | info | warn | error (default info). Never debug in prod.
LOG_LEVEL=info

# OpenTelemetry: opt-in, zero cost when off (see .ralph/specs/observability.md).
OTEL_ENABLED=false
