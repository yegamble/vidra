# Ralph generated/runtime files (in ANY .ralph/ — root, vidra-core/, vidra-user/)
**/.ralph/.call_count
**/.ralph/.last_reset
**/.ralph/.loop_start_sha
**/.ralph/.token_count
**/.ralph/.exit_signals
**/.ralph/status.json
**/.ralph/progress.json
**/.ralph/live.log
**/.ralph/.ralph_session
**/.ralph/.ralph_session_history
**/.ralph/.claude_session_id
**/.ralph/.response_analysis
**/.ralph/.circuit_breaker_state
**/.ralph/.circuit_breaker_history

# Ralph logs and generated docs (in any .ralph/)
**/.ralph/logs/*
!**/.ralph/logs/.gitkeep
**/.ralph/docs/generated/*
!**/.ralph/docs/generated/.gitkeep

# Ralph backup directories (created by migration)
.ralph_backup_*

# General logs
*.log

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
.temp/

# --- Go (vidra-core) ---
bin/
dist/
*.test
*.out

# --- Node / Next.js (vidra-user) ---
node_modules/
.next/
out/
coverage/
playwright-report/
test-results/
*.tsbuildinfo
.env
.env.local
.env.*.local

# Python cache
__pycache__/
*.pyc

# Rust build
target/

# IDE files
.vscode/
.idea/
*.swp
*.swo
