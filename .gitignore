# Component repositories — cloned by ./bootstrap.sh as INDEPENDENT git checkouts.
# They are not tracked by this meta-repo (each has its own github.com/yegamble/<name> repo).
/vidra-core/
/vidra-user/

# Ralph runtime/generated files (root .ralph/ is kept for its product specs/docs)
**/.ralph/.call_count
**/.ralph/.last_reset
**/.ralph/.last_output_length
**/.ralph/.loop_start_sha
**/.ralph/.token_count
**/.ralph/.exit_signals
**/.ralph/status.json
**/.ralph/progress.json
**/.ralph/live.log
**/.ralph/.ralph_session
**/.ralph/.ralph_session_history
**/.ralph/.claude_session_id
**/.ralph/.response_analysis
**/.ralph/.circuit_breaker_state
**/.ralph/.circuit_breaker_history
**/.ralph/logs/*
!**/.ralph/logs/.gitkeep
**/.ralph/docs/generated/*
!**/.ralph/docs/generated/.gitkeep
.ralph_backup_*

# Logs / OS / temp
*.log
.DS_Store
Thumbs.db
*.tmp
.temp/

# IDE files
.vscode/
.idea/
*.swp
*.swo
.gstack/
.playwright-mcp/
